# ============================================================
# DreamCart Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server Port (default: 5001)
PORT=5001

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/dreamcart

# JWT Secret Key — make this a long random string
JWT_SECRET=replace_this_with_a_long_random_secret_key_dreamcart_2026
